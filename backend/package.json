{
  "name": "@atena/backend",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -b",
    "start": "node dist/app.js",
    "test": "echo \"no tests yet\" && exit 0",
    "db:migrate": "tsx ../node_modules/knex/bin/cli.js migrate:latest",
    "db:migrate:make": "tsx ../node_modules/knex/bin/cli.js migrate:make",
    "db:rollback": "tsx ../node_modules/knex/bin/cli.js migrate:rollback",
    "db:seed": "tsx ../node_modules/knex/bin/cli.js seed:run",
    "db:migrate:test": "tsx ../node_modules/knex/bin/cli.js migrate:latest --env test",
    "db:rollback:test": "tsx ../node_modules/knex/bin/cli.js migrate:rollback --env test"
  },
  "dependencies": {
    "@atena/shared": "^0.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "knex": "^3.2.10",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
